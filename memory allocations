#include <stdio.h>

int main() {
    int m, p, i, j;
    int mem[10], proc[10], alloc[10];

    printf("Enter number of memory blocks: ");
    scanf("%d", &m);

    printf("Enter size of each block:\n");
    for(i=0;i<m;i++)
        scanf("%d",&mem[i]);

    printf("Enter number of processes: ");
    scanf("%d",&p);

    printf("Enter size of each process:\n");
    for(i=0;i<p;i++) {
        scanf("%d",&proc[i]);
        alloc[i] = -1;
    }

    for(i=0;i<p;i++) {
        for(j=0;j<m;j++) {
            if(mem[j] >= proc[i]) {
                alloc[i] = j;
                mem[j] -= proc[i];
                break;
            }
        }
    }

    printf("\nProcess\tSize\tBlock\n");
    for(i=0;i<p;i++) {
        if(alloc[i] != -1)
            printf("P%d\t%d\t%d\n", i+1, proc[i], alloc[i]+1);
        else
            printf("P%d\t%d\tNot Allocated\n", i+1, proc[i]);
    }

    return 0;
}


#include <stdio.h>

int main() {
    int m, p, i, j;
    int mem[10], proc[10], alloc[10];

    printf("Enter number of memory blocks: ");
    scanf("%d", &m);

    printf("Enter size of each block:\n");
    for(i=0;i<m;i++)
        scanf("%d",&mem[i]);

    printf("Enter number of processes: ");
    scanf("%d", &p);

    printf("Enter size of each process:\n");
    for(i=0;i<p;i++) {
        scanf("%d",&proc[i]);
        alloc[i] = -1;
    }

    for(i=0;i<p;i++) {
        int best = -1;
        for(j=0;j<m;j++) {
            if(mem[j] >= proc[i]) {
                if(best == -1 || mem[j] < mem[best])
                    best = j;
            }
        }
        if(best != -1) {
            alloc[i] = best;
            mem[best] -= proc[i];
        }
    }

    printf("\nProcess\tSize\tBlock\n");
    for(i=0;i<p;i++) {
        if(alloc[i] != -1)
            printf("P%d\t%d\t%d\n", i+1, proc[i], alloc[i]+1);
        else
            printf("P%d\t%d\tNot Allocated\n", i+1, proc[i]);
    }

    return 0;
}
